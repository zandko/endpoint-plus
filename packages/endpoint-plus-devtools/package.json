{
  "name": "endpoint-plus-devtools",
  "version": "1.0.2",
  "description": "Vite DevTools companion plugin for endpoint-plus, featuring API scanner and automated TypeScript type generation.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Zan <zandko@126.com>",
  "license": "MIT",
  "homepage": "https://github.com/zandko/endpoint-plus#readme",
  "bugs": {
    "url": "https://github.com/zandko/endpoint-plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zandko/endpoint-plus.git",
    "directory": "packages/endpoint-plus-devtools"
  },
  "keywords": [
    "endpoint-plus",
    "vite-plugin",
    "devtools",
    "typegen",
    "typescript",
    "http-client",
    "api-scanner",
    "code-generator",
    "quicktype"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./vite": {
      "import": "./src/vite.ts",
      "types": "./src/vite.d.ts"
    }
  },
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@vue/compiler-sfc": "^3.5.35",
    "@vueuse/core": "^14.3.0",
    "endpoint-plus": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.47.0",
    "fast-glob": "^3.3.3",
    "launch-editor": "^2.14.1",
    "mime-types": "^3.0.2",
    "pluralize": "^8.0.0",
    "reka-ui": "^2.10.0",
    "ufo": "^1.6.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/mime-types": "^3.0.1",
    "@types/pluralize": "^0.0.33",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.8"
  }
}
